#!/usr/bin/env python3
"""Test stub emulating Check Point mgmt_cli for the hit-count reporter.

Behaviors that matter for hitcount.sh:
- credentials: -r true | api-key TESTKEY | user admin + MGMT_CLI_PASSWORD=secret
- a 'password' parameter on argv is a TEST VIOLATION (must use env)
- show access-rulebase REQUIRES show-hits true and valid hits-settings dates
  (YYYY-MM-DD); when $STUB_CAPTURE is set, the received hits-settings are
  appended there as JSON lines so tests can assert the 6-month default
- every list response is paginated with tiny pages to exercise paging loops
"""
import json
import os
import re
import sys


def die(msg, code="generic_error"):
    print(json.dumps({"code": code, "message": msg}))
    sys.exit(1)


def load_fixtures():
    p = os.environ.get("HITS_FIXTURES") or os.path.join(
        os.path.dirname(os.path.abspath(__file__)), "..", "fixtures.json")
    with open(p) as f:
        return json.load(f)


def parse(argv):
    flags, pos = {}, []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a.startswith("-"):
            flags[a] = argv[i + 1] if i + 1 < len(argv) else ""
            i += 2
        else:
            pos.append(a)
            i += 1
    return flags, pos


def pairs(lst):
    return {lst[i]: lst[i + 1] for i in range(0, len(lst) - 1, 2)}


def page(objs, off, size, key="objects"):
    sl = objs[off:off + size]
    return {key: sl, "from": off + 1 if sl else off,
            "to": off + len(sl), "total": len(objs)}


def capture(record):
    path = os.environ.get("STUB_CAPTURE")
    if path:
        with open(path, "a") as f:
            f.write(json.dumps(record) + "\n")


DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def main():
    fx = load_fixtures()
    flags, pos = parse(sys.argv[1:])
    if not pos:
        die("missing command")
    cmd = pos[0]

    if cmd == "login":
        p = pairs(pos[1:])
        if "password" in p:
            print("TEST-VIOLATION: password passed on mgmt_cli argv", file=sys.stderr)
            sys.exit(1)
        root = flags.get("-r") == "true"
        apikey_ok = p.get("api-key") == "TESTKEY"
        user_ok = (p.get("user") == "admin"
                   and os.environ.get("MGMT_CLI_PASSWORD") == "secret")
        if not (root or apikey_ok or user_ok):
            die("Authentication to server failed.", "err_login_failed")
        d = p.get("domain", "")
        if d and d not in fx["domains"]:
            die("Domain not found: %s" % d)
        print(json.dumps({"sid": "sid-" + (d or "MDS"), "session-timeout": 600}))
        return

    sid = flags.get("--session-id")
    if not sid:
        die("Missing session id", "err_login_expired")

    if cmd == "logout":
        print(json.dumps({"message": "OK"}))
        return

    if cmd != "show" or len(pos) < 2:
        die("Unknown command: %s" % " ".join(pos))
    what = pos[1]
    p = pairs(pos[2:])
    off = int(p.get("offset", 0))
    domain = sid[len("sid-"):]

    if what == "domains":
        if sid != "sid-MDS":
            die("show-domains is only available in the MDS context")
        objs = [{"name": d, "type": "domain"} for d in fx["domains"]]
        print(json.dumps(page(objs, off, 1)))
    elif what == "access-layers":
        # real API quirk: container key is "access-layers", not "objects"
        names = fx["layers"].get(domain, [])
        objs = [{"name": n, "type": "access-layer"} for n in names]
        print(json.dumps(page(objs, off, 1, key="access-layers")))
    elif what == "access-rulebase":
        name = p.get("name")
        if name not in fx["rulebase"]:
            die("Requested object [%s] not found" % name,
                "generic_err_object_not_found")
        if p.get("show-hits") != "true":
            die("show-hits must be requested", "err_validation_failed")
        f_date = p.get("hits-settings.from-date", "")
        t_date = p.get("hits-settings.to-date", "")
        if not DATE_RE.match(f_date) or not DATE_RE.match(t_date):
            die("Invalid hits-settings dates [%s..%s]" % (f_date, t_date),
                "err_validation_failed")
        capture({"transport": "mgmt_cli", "layer": name, "domain": domain,
                 "from": f_date, "to": t_date,
                 "target": p.get("hits-settings.target", "")})
        print(json.dumps(page(fx["rulebase"][name], off, 2, key="rulebase")))
    else:
        die("Unknown show command: %s" % what)


main()
