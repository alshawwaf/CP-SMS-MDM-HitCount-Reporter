#!/usr/bin/env python3
"""Test stub emulating Gaia R82.10 clish 'mgmt' commands for the hit-count
reporter. Mirrors the real behaviors the tool depends on:

- sessions never survive the clish process; piped stdin ignored
- only '-c <cmd>' and '-i -f <file>' execute; api-key login is CLINFR0329
- 'mgmt login user X password Y [domain D]' works; bad creds -> MGMT9000
- batch output pollutes 'Processing line N out of M ' glued to output
- show access-rulebase requires show-hits true + valid hits-settings dates;
  received hits-settings are appended to $STUB_CAPTURE as JSON lines
"""
import json
import os
import re
import shlex
import sys

DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")


def load_fixtures():
    p = os.environ.get("HITS_FIXTURES") or os.path.join(
        os.path.dirname(os.path.abspath(__file__)), "..", "fixtures.json")
    with open(p) as f:
        return json.load(f)


def split_params(tokens):
    flags, params = {}, {}
    i = 0
    while i < len(tokens):
        t = tokens[i]
        v = tokens[i + 1] if i + 1 < len(tokens) else ""
        if t.startswith("--"):
            flags[t] = v
        else:
            params[t] = v
        i += 2
    return flags, params


def page(objs, off, size, key="objects"):
    sl = objs[off:off + size]
    return {key: sl, "from": off + 1 if sl else off,
            "to": off + len(sl), "total": len(objs)}


def capture(record):
    path = os.environ.get("STUB_CAPTURE")
    if path:
        with open(path, "a") as f:
            f.write(json.dumps(record) + "\n")


class Session:
    def __init__(self):
        self.active = False
        self.domain = ""


def run_mgmt(tokens, sess, fx):
    action = tokens[1] if len(tokens) > 1 else ""
    if action == "login":
        rest = tokens[2:]
        if rest and rest[0] == "api-key":
            return "CLINFR0329  Invalid command:'%s'." % " ".join(tokens)
        _, p = split_params(rest)
        ok = p.get("user") == "admin" and p.get("password") == "secret"
        d = p.get("domain", "")
        if d and d not in fx["domains"]:
            ok = False
        if not ok:
            return '  MGMT9000  code: "err_login_failed"'
        sess.active, sess.domain = True, d
        return ""
    if action == "logout":
        sess.active = False
        return ""
    if action == "show" and len(tokens) > 2:
        if not sess.active:
            return '  MGMT9205  You are not logged in to management server'
        what = tokens[2]
        _, p = split_params(tokens[3:])
        off = int(p.get("offset", 0))
        if what == "domains":
            if sess.domain:
                return "show-domains is only available in the MDS context"
            objs = [{"name": d, "type": "domain"} for d in fx["domains"]]
            return json.dumps(page(objs, off, 1), indent=2)
        if what == "access-layers":
            # real API quirk: container key is "access-layers", not "objects"
            names = fx["layers"].get(sess.domain, [])
            objs = [{"name": n, "type": "access-layer"} for n in names]
            return json.dumps(page(objs, off, 1, key="access-layers"), indent=2)
        if what == "access-rulebase":
            name = p.get("name")
            if name not in fx["rulebase"]:
                return "Requested object [%s] not found" % name
            if p.get("show-hits") != "true":
                return "show-hits must be requested"
            f_date = p.get("hits-settings.from-date", "")
            t_date = p.get("hits-settings.to-date", "")
            if not DATE_RE.match(f_date) or not DATE_RE.match(t_date):
                return "Invalid hits-settings dates"
            capture({"transport": "clish", "layer": name, "domain": sess.domain,
                     "from": f_date, "to": t_date,
                     "target": p.get("hits-settings.target", "")})
            return json.dumps(page(fx["rulebase"][name], off, 2, key="rulebase"),
                              indent=2)
    return "CLINFR0329  Invalid command:'%s'." % " ".join(tokens)


def main():
    args = sys.argv[1:]
    if "password" in args:
        print("TEST-VIOLATION: password on clish argv", file=sys.stderr)
        sys.exit(1)

    cmdfile = None
    single = None
    i = 0
    while i < len(args):
        if args[i] == "-f" and i + 1 < len(args):
            cmdfile = args[i + 1]; i += 2
        elif args[i] == "-c" and i + 1 < len(args):
            single = args[i + 1]; i += 2
        else:
            i += 1

    fx = load_fixtures()
    sess = Session()

    if single is not None:
        tokens = shlex.split(single)
        if tokens and tokens[0] == "mgmt":
            out = run_mgmt(tokens, sess, fx)
            if out:
                print(out)
            sys.exit(1 if ("CLINFR" in out or "MGMT9" in out) else 0)
        print("CLINFR0329  Invalid command", file=sys.stderr)
        sys.exit(1)

    if cmdfile is not None:
        with open(cmdfile) as f:
            lines = [ln.strip() for ln in f if ln.strip()]
        total = len(lines)
        for n, ln in enumerate(lines, 1):
            tokens = shlex.split(ln)
            if not tokens or tokens[0] != "mgmt":
                continue
            out = run_mgmt(tokens, sess, fx)
            sys.stdout.write("Processing line %d out of %d " % (n, total))
            if out:
                sys.stdout.write(out)
            sys.stdout.write("\n")
        sys.exit(0)

    sys.exit(1)


main()
